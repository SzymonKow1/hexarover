Panels:
  - Class: rviz_common/Displays
    Help Height: 78
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /LaserScan1
        - /Marker1
      Splitter Ratio: 0.5
    Tree Height: 549
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Views
    Invert Zero Pitch: false
    Name: Views
    Saved:
      - Class: rviz_default_plugins/TopDownOrtho
        Angle: 0
        Enable Stereo Rendering:
          Stereo Eye Separation: 0.05999999865889549
          Stereo Focal Distance: 1
          Swap Stereo Eyes: false
          Value: false
        Invert Z Axis: false
        Name: TopDown (domyślny)
        Near Clip Distance: 0.009999999776482582
        Scale: 80
        Target Frame: laser
        Value: TopDownOrtho (rviz_default_plugins)
        X: 0
        Y: 0
    Current:
      Class: rviz_default_plugins/TopDownOrtho
      Angle: 0
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.05999999865889549
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Invert Z Axis: false
      Name: TopDown
      Near Clip Distance: 0.009999999776482582
      Scale: 80
      Target Frame: laser
      Value: TopDownOrtho (rviz_default_plugins)
      X: 0
      Y: 0
Visualization Manager:
  Class: ""
  Displays:
    # ── 1. Skan lasera ───────────────────────────────────────────────────
    - Alpha: 1
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 10
        Min Value: -10
        Value: true
      Axis: Z
      Channel Name: intensity
      Class: rviz_default_plugins/LaserScan
      Color: 255; 255; 255       # białe punkty
      Color Transformer: FlatColor
      Decay Time: 0
      Enabled: true
      Invert Rainbow: false
      Max Color: 255; 255; 255
      Max Intensity: 4096
      Min Color: 0; 0; 0
      Min Intensity: 0
      Name: LaserScan
      Position Transformer: XYZ
      Selectable: true
      Size (Pixels): 3
      Size (m): 0.009999999776482582
      Style: Points
      Topic:
        Depth: 5
        Durability Policy: Volatile
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /scan
      Use Fixed Frame: true
      Use rainbow: true
      Value: true

    # ── 2. Marker człowieka (zielony cylinder z vision_node) ─────────────
    - Class: rviz_default_plugins/Marker
      Enabled: true
      Name: Marker - human
      Namespaces:
        rescue_target: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /human_marker
      Value: true

    # ── 3. TF – ramki współrzędnych (laser, lidar_link, camera_link) ─────
    - Class: rviz_default_plugins/TF
      Enabled: true
      Frame Timeout: 15
      Frames:
        All Enabled: true
      Marker Scale: 0.5
      Name: TF
      Show Arrows: true
      Show Axes: true
      Show Names: true
      Tree:
        {}
      Update Interval: 0
      Value: true

    # ── 4. Oś robota / origin ─────────────────────────────────────────────
    - Class: rviz_default_plugins/Axes
      Enabled: true
      Length: 0.5
      Name: Axes - laser origin
      Radius: 0.009999999776482582
      Reference Frame: laser
      Value: true

  Enabled: true
  Global Options:
    Background Color: 25; 25; 25
    Fixed Frame: laser
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz_default_plugins/Interact
      Hide Inactive Objects: true
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
  Value: true
  Views:
    Current:
      Class: rviz_default_plugins/TopDownOrtho
      Angle: 0
      Name: TopDown
      Scale: 80
      Target Frame: laser
      X: 0
      Y: 0
    Saved: ~
Window Geometry:
  Displays:
    collapsed: false
  Height: 900
  Hide Left Dock: false
  Hide Right Dock: true
  QMainWindow State: ""
  Views:
    collapsed: false
  Width: 1400
  X: 50
  Y: 50
